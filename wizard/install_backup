[
    {
        "stepTitle": "初始配置",
        "items": [
            {
                "type": "text",
                "field": "qwenpaw_webui_port",
                "label": "WebUI端口",
                "initValue": "2277",
                "rules": [
                    {
                        "required": true,
                        "message": "请输入端口号"
                    },
                    {
                        "pattern": "^([1-9][0-9]{0,3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5])$",
                        "message": "端口号必须为1-65535之间的数字"
                    }
                ]
            },
            {
                "type": "text",
                "field": "qwenpaw_auth_username",
                "label": "设置用户名",
                "rules": [
                    {
                        "required": true,
                        "message": "请输入用户名"
                    },
                    {
                        "pattern": "^[a-zA-Z0-9_]+$",
                        "message": "用户名只能包含字母、数字和下划线"
                    }
                ]
            },
            {
                "type": "password",
                "field": "qwenpaw_auth_password",
                "label": "设置密码",
                "initValue": "admin",
                "rules": [
                    {
                        "required": true,
                        "message": "请输入密码"
                    },
                    {
                        "min": 6,
                        "message": "密码长度不能少于6位"
                    }
                ]
            },
            {
                "type": "password",
                "field": "qwenpaw_auth_password_confirm",
                "label": "确认密码",
                "rules": [
                    {
                        "required": true,
                        "message": "请确认密码"
                    }
                ]
            }
        ]
    }
]